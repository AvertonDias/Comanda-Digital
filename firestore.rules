/**
 * Filosofia: Este conjunto de regras implementa um modelo de controle de acesso baseado em papéis (RBAC).
 * O acesso a qualquer dado de um restaurante é determinado pelo papel do usuário naquele restaurante específico.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRestaurantRoleData(restaurantId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId)).data;
    }

    function isRestaurantStaff(restaurantId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId));
    }

    function isRestaurantAdmin(restaurantId) {
      let roleData = getRestaurantRoleData(restaurantId);
      return isRestaurantStaff(restaurantId) && roleData.role == 'admin' && roleData.isActive == true;
    }

    // --- Regras por Coleção ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /restaurantRoles/{restaurantId} {
        allow read: if isOwner(userId) || isRestaurantAdmin(restaurantId);
        allow create: if isSignedIn(); // Permite criar o papel inicial ao registrar restaurante
        allow update, delete: if isRestaurantAdmin(restaurantId);
      }
    }

    // Suporte para collectionGroup queries em restaurantRoles (usado no gerenciamento de equipe)
    match /{path=**}/restaurantRoles/{restaurantId} {
      allow list: if isSignedIn() && (isOwner(path[1]) || isRestaurantAdmin(restaurantId));
    }

    match /restaurants/{restaurantId} {
      allow get: if isRestaurantStaff(restaurantId);
      allow create: if isSignedIn();
      allow update, delete: if isRestaurantAdmin(restaurantId);

      // Regras específicas para subcoleções para maior controle
      match /menuItemCategories/{catId} {
        allow read: if isRestaurantStaff(restaurantId);
        allow write: if isRestaurantAdmin(restaurantId);
      }
      
      match /menuItems/{itemId} {
        allow read: if isRestaurantStaff(restaurantId);
        allow write: if isRestaurantAdmin(restaurantId);
      }

      match /printSectors/{sectorId} {
        allow read: if isRestaurantStaff(restaurantId);
        allow write: if isRestaurantAdmin(restaurantId);
      }

      match /printers/{printerId} {
        allow read: if isRestaurantStaff(restaurantId);
        allow write: if isRestaurantAdmin(restaurantId);
      }

      // Pedidos e Mesas podem ser manipulados por garçons (staff)
      match /{allStaffSubcollections=**} {
        allow read, write: if isRestaurantStaff(restaurantId);
      }
    }
  }
}