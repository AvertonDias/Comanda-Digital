
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem um papel ativo no restaurante
    // Equipe tem acesso total no seu restaurante
    function isRestaurantStaff(restaurantId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId))
      );
    }

    // --- Regras por Coleção ---

    // Perfis de Usuário e Papéis
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /restaurantRoles/{restaurantId} {
        allow read: if isSignedIn();
        // Membros da equipe podem gerenciar papéis para o mesmo restaurante
        allow write: if isSignedIn() && (request.auth.uid == userId || isRestaurantStaff(restaurantId));
      }
    }

    // Regra para buscar o restaurante do usuário via Collection Group
    // Essencial para o login e identificação do restaurante
    match /{path=**}/restaurantRoles/{restaurantId} {
      allow read, list: if isSignedIn();
    }

    // Coleção Principal de Restaurantes e suas Subcoleções
    match /restaurants/{restaurantId} {
      // Qualquer usuário logado pode criar um restaurante
      allow create: if isSignedIn();
      
      // Permite acesso total se for membro da equipe do restaurante específico
      allow read, write: if isRestaurantStaff(restaurantId);

      // Regras recursivas para todas as subcoleções (menu, pedidos, mesas, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isRestaurantStaff(restaurantId);
      }
    }
  }
}
