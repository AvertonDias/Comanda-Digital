/**
 * Filosofia: Este conjunto de regras implementa um modelo de controle de acesso baseado em papéis (RBAC) para um sistema multi-restaurante.
 * O acesso a qualquer dado de um restaurante é determinado pelo papel do usuário naquele restaurante específico.
 *
 * Estrutura de Dados: Os dados são organizados sob /restaurants/{restaurantId}, criando um ambiente seguro para cada restaurante.
 * As permissões de usuário são gerenciadas em /users/{userId}/restaurantRoles/{restaurantId}, que mapeia um UID de autenticação
 * a um papel dentro de um restaurante, permitindo uma verificação de permissão eficiente e segura.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRestaurantRoleData(restaurantId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId)).data;
    }

    function isRestaurantStaff(restaurantId) {
      let roleData = getRestaurantRoleData(restaurantId);
      return isSignedIn() && roleData != null && roleData.isActive == true;
    }

    function isRestaurantAdmin(restaurantId) {
      let roleData = getRestaurantRoleData(restaurantId);
      return isRestaurantStaff(restaurantId) && roleData.role == 'admin';
    }

    // --- Regras por Coleção ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /restaurants/{restaurantId} {
      allow get: if isRestaurantStaff(restaurantId);
      // Permite criar se estiver logado
      allow create: if isSignedIn();
      allow update, delete: if isRestaurantAdmin(restaurantId);
    }

    match /users/{userId}/restaurantRoles/{restaurantId} {
      allow get, list: if isOwner(userId) || isRestaurantAdmin(restaurantId);
      
      // Permite criar se for o dono do perfil E o restaurante ainda não existir (criação inicial)
      // OU se já for um admin do restaurante gerenciando outros usuários
      allow create: if (isOwner(userId) && !exists(/databases/$(database)/documents/restaurants/$(restaurantId)))
                    || isRestaurantAdmin(restaurantId);
                    
      allow update, delete: if isRestaurantAdmin(restaurantId);
    }

    // O cardápio é público para leitura, mas apenas funcionários podem editar
    match /restaurants/{restaurantId}/menuItemCategories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantStaff(restaurantId);
    }

    match /restaurants/{restaurantId}/menuItems/{itemId} {
      allow get, list: if true;
      allow create, update, delete: if isRestaurantStaff(restaurantId);
    }
    
    // Setores e Impressoras são dados de configuração interna
    match /restaurants/{restaurantId}/printSectors/{sectorId} {
      allow get, list: if isRestaurantStaff(restaurantId);
      allow create, update, delete: if isRestaurantAdmin(restaurantId);
    }

    match /restaurants/{restaurantId}/printers/{printerId} {
      allow get, list: if isRestaurantStaff(restaurantId);
      allow create, update, delete: if isRestaurantAdmin(restaurantId);
    }

    // Mesas são gerenciadas por funcionários
    match /restaurants/{restaurantId}/tables/{tableId} {
      allow get, list: if isRestaurantStaff(restaurantId);
      allow create, update, delete: if isRestaurantStaff(restaurantId);
    }

    // Clientes são gerenciados por funcionários
    match /restaurants/{restaurantId}/customers/{customerId} {
      allow get, list: if isRestaurantStaff(restaurantId);
      allow create, update, delete: if isRestaurantStaff(restaurantId);
    }

    // Pedidos são o coração do sistema, gerenciados por funcionários
    match /restaurants/{restaurantId}/orders/{orderId} {
      allow get, list, create, update: if isRestaurantStaff(restaurantId);
      allow delete: if isRestaurantAdmin(restaurantId);

      // Itens de um pedido
      match /items/{orderItemId} {
        allow get, list, create, update: if isRestaurantStaff(restaurantId);
        allow delete: if isRestaurantAdmin(restaurantId);
      }
    }
  }
}