
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Validação baseada no activeRestaurantId salvo no perfil do usuário
    function isStaff(restaurantId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRestaurantId == restaurantId
      );
    }

    function isAdmin(restaurantId) {
      // Um admin deve ser staff e ter o papel "admin" na equipe
      return isSignedIn() && (
        get(/databases/$(database)/documents/restaurants/$(restaurantId)/team/$(request.auth.uid)).data.role == "admin"
      );
    }

    // USERS: Perfil público do usuário
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // RESTAURANTS
    match /restaurants/{restaurantId} {
      allow create: if isSignedIn();
      allow read: if true; // Cardápio e infos básicas são públicos
      allow update, delete: if isAdmin(restaurantId);

      // Equipe do restaurante
      match /team/{memberId} {
        // Permite ler se for o próprio membro ou se for staff do restaurante
        allow read: if isSignedIn() && (request.auth.uid == memberId || isStaff(restaurantId));
        // Apenas admins podem gerenciar a equipe, mas o próprio usuário pode se "vincular" ao aceitar convite
        allow write: if isAdmin(restaurantId) || (isSignedIn() && request.auth.uid == memberId);
      }

      match /invitations/{inviteId} {
        allow read: if true; 
        allow write: if isAdmin(restaurantId);
      }

      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isStaff(restaurantId);
      }

      match /menuItemCategories/{catId} {
        allow read: if true;
        allow write: if isStaff(restaurantId);
      }

      match /tables/{tableId} {
        allow read: if true;
        allow write: if isStaff(restaurantId);
      }

      match /customers/{customerId} {
        allow read, write: if isStaff(restaurantId);
      }

      match /orders/{orderId} {
        allow read: if true; // Pedidos podem ser lidos pelo cliente/QR
        allow write: if true; // Clientes criam pedidos via QR, Staff gerencia
        
        match /items/{itemId} {
          allow read, write: if true;
        }
      }

      // Fallback para outras subcoleções
      match /{allSubcollections=**} {
        allow read, write: if isStaff(restaurantId);
      }
    }
  }
}
