
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem um papel ativo no restaurante
    // Membros da equipe têm acesso total para garantir operação fluida
    function isRestaurantStaff(restaurantId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId))
      );
    }

    // --- Regras por Coleção ---

    // Perfis de Usuário e Papéis
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /restaurantRoles/{restaurantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == userId || isRestaurantStaff(restaurantId));
      }
    }

    // Regra crítica para o login e identificação de restaurante
    // Permite a consulta de grupo para encontrar os papéis do usuário
    match /{path=**}/restaurantRoles/{roleId} {
      allow read, list: if isSignedIn();
    }

    // Coleção Principal de Restaurantes e suas Subcoleções
    match /restaurants/{restaurantId} {
      // Qualquer usuário logado pode criar um restaurante (registro)
      allow create: if isSignedIn();
      
      // Permite acesso total se for membro da equipe (Staff)
      // Nivelado para "fazer tudo" conforme solicitado
      allow read, write: if isRestaurantStaff(restaurantId);

      // Regras recursivas para todas as subcoleções (menu, pedidos, mesas, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isRestaurantStaff(restaurantId);
      }
    }
  }
}
