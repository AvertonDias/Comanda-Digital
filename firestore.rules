rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole(restaurantId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId));
    }

    function isStaff(restaurantId) {
      return isSignedIn()
        && getRole(restaurantId).exists()
        && getRole(restaurantId).data.isActive == true;
    }

    function isAdmin(restaurantId) {
      return isStaff(restaurantId)
        && getRole(restaurantId).data.role == "admin";
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;

      match /restaurantRoles/{restaurantId} {
        allow read: if request.auth.uid == userId || isStaff(restaurantId);
        allow create, update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin(restaurantId));
      }
    }

    // Permite consultas de grupo para encontrar os papéis do usuário
    match /{path=**}/restaurantRoles/{roleId} {
      allow read, list: if isSignedIn() && (
        resource == null || 
        resource.data.userId == request.auth.uid || 
        isStaff(resource.data.restaurantId)
      );
    }

    // RESTAURANTS
    match /restaurants/{restaurantId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn(); // Permite leitura básica para validação de acesso
      allow update, delete: if isAdmin(restaurantId);

      match /{allSubcollections=**} {
        allow read, write: if isStaff(restaurantId);
      }
    }
  }
}