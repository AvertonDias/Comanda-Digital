rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite que qualquer usuário autenticado leia e escreva em qualquer documento.
    // Esta é uma regra simplificada ideal para o estágio de prototipagem e desenvolvimento,
    // garantindo que todas as subcoleções (pedidos, itens, clientes) sejam acessíveis.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}