rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Função simplificada e performática baseada na desnormalização sugerida
    function isStaff(restaurantId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRestaurantId == restaurantId
      );
    }

    function isAdmin(restaurantId) {
      return isStaff(restaurantId) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId)).data.role == "admin"
      );
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;

      match /restaurantRoles/{restaurantId} {
        allow read: if request.auth.uid == userId || isStaff(restaurantId);
        allow create, update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin(restaurantId));
      }
    }

    // Coleção de grupo protegida como sugerido
    match /{path=**}/restaurantRoles/{roleId} {
      allow read, list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isStaff(resource.data.restaurantId)
      );
    }

    // RESTAURANTS
    match /restaurants/{restaurantId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn(); 
      allow update, delete: if isAdmin(restaurantId);

      match /{allSubcollections=**} {
        allow read, write: if isStaff(restaurantId);
      }
    }
  }
}