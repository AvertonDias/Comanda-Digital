
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // USERS: Perfil do usuário
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // RESTAURANTS
    match /restaurants/{restaurantId} {
      // Qualquer usuário logado pode criar e qualquer um pode ver (para o cardápio público)
      allow create: if isSignedIn();
      allow read: if true; 
      allow update, delete: if isSignedIn();

      // Equipe do restaurante
      match /team/{memberId} {
        allow read, write: if isSignedIn();
      }

      // Pedidos: Clientes via QR e Staff gerenciam
      match /orders/{orderId} {
        allow read, write: if true;
        
        match /items/{itemId} {
          allow read, write: if true;
        }
      }

      // Cardápio e Categorias
      match /menuItems/{itemId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /menuItemCategories/{catId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // Mesas, Clientes, Impressoras e Setores
      match /tables/{tableId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /customers/{customerId} {
        allow read, write: if isSignedIn();
      }

      match /invitations/{inviteId} {
        allow read: if true; 
        allow write: if isSignedIn();
      }

      // Fallback para subcoleções
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
