
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Validação ultra-rápida baseada na desnormalização (activeRestaurantId no doc do user)
    function isStaff(restaurantId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activeRestaurantId == restaurantId
      );
    }

    function isAdmin(restaurantId) {
      return isStaff(restaurantId) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId)).data.role == "admin"
      );
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;

      match /restaurantRoles/{restaurantId} {
        allow read: if request.auth.uid == userId || isStaff(restaurantId);
        allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin(restaurantId));
        allow update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin(restaurantId));
      }
    }

    // RESTAURANTS
    match /restaurants/{restaurantId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() || true; // Permitir leitura para o cardápio público
      allow update, delete: if isAdmin(restaurantId);

      match /invitations/{inviteId} {
        allow read: if true; // Validar convite publicamente
        allow write: if isAdmin(restaurantId);
      }

      match /menuItems/{itemId} {
        allow read: if true; // Cardápio é público via link/QR
        allow write: if isStaff(restaurantId);
      }

      match /menuItemCategories/{catId} {
        allow read: if true;
        allow write: if isStaff(restaurantId);
      }

      match /tables/{tableId} {
        allow read: if true;
        allow write: if isStaff(restaurantId);
      }

      match /{allSubcollections=**} {
        allow read, write: if isStaff(restaurantId);
      }
    }

    // Support for collectionGroup queries (e.g. searching roles across restaurants)
    match /{path=**}/restaurantRoles/{roleId} {
      allow read, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isStaff(resource.data.restaurantId));
    }
  }
}
