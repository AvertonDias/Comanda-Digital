rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getRole(restaurantId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId));
    }

    function isStaff(restaurantId) {
      return isSignedIn()
        && getRole(restaurantId).exists()
        && getRole(restaurantId).data.active == true;
    }

    function isAdmin(restaurantId) {
      return isStaff(restaurantId)
        && getRole(restaurantId).data.role == "admin";
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if request.auth.uid == userId;

      match /restaurantRoles/{restaurantId} {

        // Pode ver
        allow read: if request.auth.uid == userId || isStaff(restaurantId);

        // 🔒 SOMENTE ADMIN pode criar/editar/deletar roles
        allow create, update, delete: if isAdmin(restaurantId);
      }
    }

    // collectionGroup
    match /{path=**}/restaurantRoles/{roleId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isStaff(resource.data.restaurantId)
      );

      allow list: if isSignedIn();
    }

    // RESTAURANTS
    match /restaurants/{restaurantId} {

      // criação inicial
      allow create: if isSignedIn();

      allow read: if isStaff(restaurantId);

      // só admin altera restaurante
      allow update, delete: if isAdmin(restaurantId);

      match /{allSubcollections=**} {
        allow read, write: if isStaff(restaurantId);
      }
    }
  }
}