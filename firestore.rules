
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // USERS: Perfil do usuário
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // RESTAURANTS
    match /restaurants/{restaurantId} {
      // Qualquer usuário logado pode criar um restaurante
      allow create: if isSignedIn();
      // Leitura básica do restaurante é pública (para o cardápio)
      allow get, list: if true; 
      allow update, delete: if isSignedIn();

      // Equipe do restaurante
      match /team/{memberId} {
        allow get, list, write: if isSignedIn();
      }

      // Pedidos: Acesso total para permitir consulta via QR Code e gestão pelo Staff
      match /orders/{orderId} {
        allow get, list, write: if true;
        
        match /items/{itemId} {
          allow get, list, write: if true;
        }
      }

      // Cardápio e Categorias: Leitura pública, escrita para staff
      match /menuItems/{itemId} {
        allow get, list: if true;
        allow write: if isSignedIn();
      }

      match /menuItemCategories/{catId} {
        allow get, list: if true;
        allow write: if isSignedIn();
      }

      // Mesas e Convites: Leitura pública
      match /tables/{tableId} {
        allow get, list: if true;
        allow write: if isSignedIn();
      }

      match /invitations/{inviteId} {
        allow get, list: if true; 
        allow write: if isSignedIn();
      }

      // Clientes, Impressoras e Setores: Requer autenticação
      match /customers/{customerId} {
        allow get, list, write: if isSignedIn();
      }

      match /printSectors/{sectorId} {
        allow get, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /printers/{printerId} {
        allow get, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      // Fallback para qualquer outra subcoleção
      match /{allSubcollections=**} {
        allow get, list, write: if isSignedIn();
      }
    }
  }
}
