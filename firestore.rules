rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem um papel ativo no restaurante
    function isRestaurantStaff(restaurantId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId))
      );
    }

    // --- Regras por Coleção ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;

      match /restaurantRoles/{restaurantId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == userId || isRestaurantStaff(restaurantId));
      }
    }

    // Regra para consultas de grupo (collectionGroup)
    // Permite que o usuário liste seus próprios papéis ou veja papéis do seu restaurante se for staff
    match /{path=**}/restaurantRoles/{roleId} {
      allow list: if isSignedIn();
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isRestaurantStaff(resource.data.restaurantId));
      allow write: if isSignedIn() && (request.auth.uid == resource.data.userId || isRestaurantStaff(resource.data.restaurantId));
    }

    match /restaurants/{restaurantId} {
      allow create: if isSignedIn();
      allow read, write: if isRestaurantStaff(restaurantId);

      match /{allSubcollections=**} {
        allow read, write: if isRestaurantStaff(restaurantId);
      }
    }
  }
}