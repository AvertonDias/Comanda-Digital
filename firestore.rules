
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Funções Auxiliares ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica se o usuário logado tem um papel ativo no restaurante
    // Corrigido para ser mais resiliente e permitir consultas de grupo
    function isRestaurantStaff(restaurantId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/restaurantRoles/$(restaurantId))
      );
    }

    // --- Regras por Coleção ---

    // Perfis de Usuário e Papéis
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /restaurantRoles/{restaurantId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isRestaurantStaff(restaurantId);
      }
    }

    // Regra Crítica para Collection Group (Identificação do Restaurante)
    match /{path=**}/restaurantRoles/{restaurantId} {
      allow read, list: if isSignedIn() && (request.auth.uid == resource.data.userId || isRestaurantStaff(restaurantId));
    }

    // Coleção Principal de Restaurantes e suas Subcoleções
    match /restaurants/{restaurantId} {
      allow create: if isSignedIn();
      
      // Permite acesso total se for membro da equipe
      allow read, write: if isRestaurantStaff(restaurantId);

      // Regras recursivas para todas as subcoleções (menu, pedidos, mesas, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isRestaurantStaff(restaurantId);
      }
    }
  }
}
